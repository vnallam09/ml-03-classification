# ============================================================
# .editorconfig (ALL-REPOS)
# ============================================================
# Updated: 2026-06-27
#
# REQ: All professional GitHub project repositories MUST include .editorconfig.
# WHY: Establish a cross-editor baseline so diffs stay clean and formatting
# is consistent across editors and IDEs.
# ALT: Repository may omit .editorconfig ONLY if formatting is enforced
# equivalently by CI and formatter tooling.
# CUSTOM: Adjust indent_size defaults only if organizational standards change;
# keep stable across projects.
# EditorConfig: https://editorconfig.org

root = true


# === Core defaults ===

[*]
# WHY: Normalize line endings and encoding across Windows, macOS, and Linux.
charset = utf-8
end_of_line = lf

# WHY: Default to 2 spaces for configs and markup; language-specific overrides follow.
indent_size = 2
indent_style = space

# WHY: Newline at EOF avoids noisy diffs and tool warnings.
insert_final_newline = true

# WHY: Remove accidental whitespace noise in diffs.
trim_trailing_whitespace = true


# === Named root and metadata files ===

[CITATION.cff]
# WHY: Citation tooling expects stable YAML formatting.
indent_size = 2
indent_style = space

[CODEOWNERS]
# WHY: CODEOWNERS is a structured text file; keep formatting simple and stable.
indent_size = 2
indent_style = space

[LICENSE]
# WHY: License text should remain plain, stable, and editor-neutral.
indent_size = 2
indent_style = space


# === Build systems ===

[Makefile]
# WHY: Makefiles require tabs.
indent_style = tab

[*.mk]
# WHY: Makefile includes require tabs.
indent_style = tab


# === Markup and documentation ===

[*.md]
# WHY: Keep Markdown clean; use explicit <br> for hard line breaks.
indent_size = 2
trim_trailing_whitespace = true

[*.qmd]
# WHY: Quarto Markdown follows Markdown-style formatting.
indent_size = 2
indent_style = space

[*.rst]
# WHY: reStructuredText documentation benefits from stable 2-space indentation.
indent_size = 2
indent_style = space

[*.{bib,cls,sty,tex}]
# WHY: LaTeX and BibTeX convention is 2 spaces.
indent_size = 2
indent_style = space

[*.{css,html,xml}]
# WHY: Web and XML markup convention is 2 spaces.
indent_size = 2
indent_style = space


# === Configuration and structured text ===

[*.env]
# WHY: Environment templates should remain simple line-oriented text.
indent_size = 2
indent_style = space

[*.{cfg,ini}]
# WHY: INI-style configuration convention is 2 spaces.
indent_size = 2
indent_style = space

[*.{json,jsonc,jsonl,ndjson}]
# WHY: JSON tooling typically expects 2 spaces.
indent_size = 2
indent_style = space

[*.toml]
# WHY: TOML often follows 4-space indentation in many projects.
indent_size = 4
indent_style = space

[*.{yaml,yml}]
# WHY: YAML convention is 2 spaces.
indent_size = 2
indent_style = space


# === Programming languages and scripts ===

[*.bat]
# WHY: Windows batch files commonly use tabs or editor defaults; keep simple.
indent_size = 2
indent_style = space

[*.{bash,sh}]
# WHY: Shell script convention is 2 spaces.
indent_size = 2
indent_style = space

[*.{c,cpp,cs,go,h,hpp,java,rs}]
# WHY: Many C-family and systems languages commonly use 4 spaces.
indent_size = 4
indent_style = space

[*.jl]
# WHY: Julia convention commonly uses 4 spaces.
indent_size = 4
indent_style = space

[*.{js,ts}]
# WHY: JS/TS ecosystem commonly uses 2 spaces.
indent_size = 2
indent_style = space

[*.mojo]
# WHY: Mojo uses Python-like syntax and commonly follows 4-space indentation.
indent_size = 4
indent_style = space

[*.ps1]
# WHY: PowerShell convention is 4 spaces.
indent_size = 4
indent_style = space

[*.{py,pyi}]
# WHY: Python convention is 4 spaces.
indent_size = 4
indent_style = space

[*.{r,R}]
# WHY: R convention commonly uses 2 spaces.
indent_size = 2
indent_style = space

[*.sql]
# WHY: SQL formatting varies, but 2 spaces is a stable shared baseline.
indent_size = 2
indent_style = space


# === Formal, math, and proof languages ===

[*.lean]
# WHY: Lean 4 convention is 2 spaces; matches Mathlib and stdlib style.
indent_size = 2
indent_style = space


# === Notebooks ===

[*.ipynb]
# WHY: Jupyter notebooks are JSON documents; keep embedded formatting stable.
indent_size = 2
indent_style = space


# === Text and tabular data ===

[*.{csv,dat,psv,tsv,txt}]
# WHY: Text and tabular data should remain simple line-oriented text.
indent_size = 2
indent_style = space
